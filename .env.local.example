# ============================================================
#  .env.local.example
#  Copy this file to .env.local and fill in your real values.
#  NEVER commit .env.local to Git.
# ============================================================

# --- Supabase (public — safe to expose in frontend) ---------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase (server-only — used ONLY in Netlify Functions) -
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT signing secret (min 32 random characters) ----------
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-random-32-char-secret-string

# --- Public site URL ----------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.neogiant.com.my

# ── Jotform 表单 ID (从 Jotform 表单 URL 中获取) ─────────
# 例如 https://form.jotform.com/242345678901234 → 表单 ID 为 242345678901234
# —— Jotform 表单 IDs ——
# 1. 雇主寻工表单
NEXT_PUBLIC_JOTFORM_EMPLOYERS_ID=261731188429059

# 2. 提交简历表单
NEXT_PUBLIC_JOTFORM_RESUME_ID=261730525756056

# 3. 新建求职申请表单
NEXT_PUBLIC_JOTFORM_FORM_ID=261751098532460

# ============================================================
#  Netlify Dashboard → Site Settings → Environment Variables
#  Add ALL of the above variables there for production.
#  Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
#  Variables WITHOUT that prefix are server-side only.
# ============================================================
